# CONVEX
CONVEX_DEPLOYMENT=...
PUBLIC_CONVEX_URL=...
PUBLIC_CONVEX_SITE_URL=...
CONVEX_PRIVATE_BRIDGE_KEY=... # optional for a simple dev setup, set in both app + Convex deployment to enforce

# REMOTE RUNNER
RUNNER_API_URL=... # set on the frontend deployment; leave unset locally to use the in-process Docker runner
RUNNER_API_KEY=... # shared secret used by the frontend and the standalone runner
RUNNER_SERVER_HOST=0.0.0.0 # used by the standalone runner process
RUNNER_SERVER_PORT=3001 # used by the standalone runner process

# DOCKER RUNNER
PYTHON_RUNNER_IMAGE=python:3.12-slim-bookworm@sha256:4a8e0824201e50fc44ee8d208a2b3e44f33e00448907e524066fca5a96eb5567
